{
  "name": "@wspulse/client",
  "version": "0.1.0",
  "description": "WebSocket client for wspulse with auto-reconnect and exponential backoff",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:cover": "vitest run --coverage",
    "lint": "eslint src/ test/ && tsc --noEmit",
    "fmt": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "check": "npm run fmt && npm run lint && npm run test"
  },
  "peerDependencies": {
    "ws": ">=8"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vitest": "^3.1.1",
    "ws": "^8.18.1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wspulse/client-ts.git"
  },
  "keywords": [
    "websocket",
    "ws",
    "client",
    "reconnect",
    "backoff"
  ]
}
